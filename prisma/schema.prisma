generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL")
}

// ─── Authentication ───────────────────────────────────────────────

enum UserRole {
  USER
  ADMIN
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          UserRole  @default(USER)
  username      String?   @unique
  bio           String?
  theme              String    @default("light") // "light" | "dark"
  emailNotifications Boolean   @default(true)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  accounts   Account[]
  sessions   Session[]
  portfolios Portfolio[]

  @@index([email])
  @@index([username])
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Portfolio ────────────────────────────────────────────────────

enum PortfolioStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model Portfolio {
  id          String          @id @default(cuid())
  userId      String
  title       String
  slug        String
  description String?
  status      PortfolioStatus @default(DRAFT)
  templateId  String?
  isDefault   Boolean         @default(false)
  viewCount      Int             @default(0)
  seoTitle       String?
  seoDescription String?
  ogImageUrl     String?
  accessPassword String?
  createdAt      DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  template Template? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  sections Section[]
  theme    Theme?
  views       PortfolioView[]
  submissions ContactSubmission[]
  versions    PortfolioVersion[]

  @@unique([userId, slug])
  @@index([userId])
  @@index([slug])
  @@map("portfolios")
}

// ─── Sections (Frames / Containers) ──────────────────────────────
// Like Figma frames — a section is a layout container that holds blocks.

model Section {
  id          String   @id @default(cuid())
  portfolioId String
  name        String
  sortOrder   Int      @default(0)
  isVisible   Boolean  @default(true)
  isLocked    Boolean  @default(false)

  // Section-level layout & styling (JSON)
  // { layout, direction, gap, align, justify, padding, background, minHeight, fullWidth }
  styles      Json     @default("{}")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  portfolio Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  blocks    Block[]

  @@index([portfolioId])
  @@index([portfolioId, sortOrder])
  @@map("sections")
}

// ─── Blocks (Elements / Layers inside Sections) ──────────────────
// Like Figma layers — each block is a UI element with its own props & styles.

model Block {
  id        String  @id @default(cuid())
  sectionId String
  type      String  // "heading" | "text" | "image" | "button" | etc.
  sortOrder Int     @default(0)
  isVisible Boolean @default(true)
  isLocked  Boolean @default(false)

  // Block-specific content data (JSON) — varies by type
  // Heading → { text, level }
  // Text → { html }
  // Image → { src, alt }
  // Button → { text, url, variant }
  // SkillBar → { name, level, icon }
  // ProjectCard → { title, description, image, techStack, liveUrl, repoUrl }
  // etc.
  content   Json    @default("{}")

  // Granular visual styling (JSON) — like Figma's design panel
  // { width, maxWidth, padding, margin, fontSize, fontWeight, fontFamily,
  //   textAlign, textColor, backgroundColor, backgroundGradient,
  //   borderWidth, borderColor, borderRadius, borderStyle,
  //   boxShadow, opacity, display, gap, alignItems, justifyContent,
  //   hideOnMobile, hideOnDesktop, animation }
  styles    Json    @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  section Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@index([sectionId])
  @@index([sectionId, sortOrder])
  @@map("blocks")
}

// ─── Theming (Global Design Tokens) ──────────────────────────────

enum ThemeMode {
  LIGHT
  DARK
  CUSTOM
}

model Theme {
  id              String    @id @default(cuid())
  portfolioId     String    @unique
  mode            ThemeMode @default(DARK)
  primaryColor    String    @default("#6366f1")
  secondaryColor  String    @default("#8b5cf6")
  accentColor     String    @default("#06b6d4")
  backgroundColor String    @default("#0f172a")
  surfaceColor    String    @default("#1e293b")
  textColor       String    @default("#f8fafc")
  mutedColor      String    @default("#94a3b8")
  fontHeading     String    @default("Space Grotesk")
  fontBody        String    @default("Inter")
  fontMono        String    @default("JetBrains Mono")
  borderRadius    String    @default("0.5rem")
  customCss       String?   @db.Text
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  portfolio Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@map("themes")
}

// ─── Templates ────────────────────────────────────────────────────

model Template {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  thumbnail   String?
  // config holds the full blueprint: sections + blocks + theme defaults
  config      Json     @default("{}")
  isActive    Boolean  @default(true)
  isPremium   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  portfolios Portfolio[]

  @@map("templates")
}

// ─── Contact Submissions ──────────────────────────────────────────

model ContactSubmission {
  id          String   @id @default(cuid())
  portfolioId String
  name        String
  email       String
  message     String   @db.Text
  createdAt   DateTime @default(now())

  portfolio Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@index([portfolioId])
  @@map("contact_submissions")
}

// ─── Version History ──────────────────────────────────────────────

model PortfolioVersion {
  id          String   @id @default(cuid())
  portfolioId String
  data        Json
  label       String?
  createdAt   DateTime @default(now())

  portfolio Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@index([portfolioId])
  @@index([portfolioId, createdAt])
  @@map("portfolio_versions")
}

// ─── Analytics ─────────────────────────────────────────────────────

model PortfolioView {
  id          String   @id @default(cuid())
  portfolioId String
  viewedAt    DateTime @default(now())
  referrer    String?
  deviceType  String?

  portfolio Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@index([portfolioId])
  @@index([portfolioId, viewedAt])
  @@map("portfolio_views")
}
